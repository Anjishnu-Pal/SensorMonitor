<?xml version="1.0" encoding="utf-8"?>
<!--
    Requirement 7 — MainActivity root layout.
    Structure:
      ┌─────────────────────────────────┐
      │  tv_status  (connection bar)    │
      ├─────────────────────────────────┤
      │  TabLayout  (Data | Graphs)     │
      ├─────────────────────────────────┤
      │                                 │
      │  ViewPager2  (fills remaining)  │
      │                                 │
      └─────────────────────────────────┘
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Live connection / status bar -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:gravity="center"
        android:text="@string/status_waiting"
        android:textColor="@color/colorStatusWaiting"
        android:textSize="13sp"
        android:background="@color/colorSurface" />

    <!-- Tab strip -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:tabTextColor="@color/grey_text"
        app:tabSelectedTextColor="@color/white"
        app:tabIndicatorColor="@color/colorAccent"
        app:tabIndicatorHeight="3dp" />

    <!-- Swipeable content area — weight=1 fills all remaining space -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
