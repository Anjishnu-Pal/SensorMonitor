<?xml version="1.0" encoding="utf-8"?>
<!--
    Requirement 7 (CRITICAL) — Tab 2: Graphical Plot.

    Three COMPLETELY SEPARATE CardView containers stacked vertically inside a
    NestedScrollView. Each CardView contains exactly ONE LineChart for ONE
    sensor parameter. They share NO data, NO axis, NO chart object.

    ┌────────────────────────────────────────────────┐
    │  CardView 1                                     │
    │    LineChart — Temperature (°C) only           │
    │    Y-axis: auto-scaled to temp range           │
    │    X-axis: Time                                │
    └────────────────────────────────────────────────┘
    ┌────────────────────────────────────────────────┐
    │  CardView 2                                     │
    │    LineChart — pH only                         │
    │    Y-axis: auto-scaled to pH range             │
    │    X-axis: Time                                │
    └────────────────────────────────────────────────┘
    ┌────────────────────────────────────────────────┐
    │  CardView 3                                     │
    │    LineChart — Glucose (mg/dL) only            │
    │    Y-axis: auto-scaled to glucose range        │
    │    X-axis: Time                                │
    └────────────────────────────────────────────────┘
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:dividerPadding="6dp">

        <!-- ── Frame 1: Temperature ───────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_temperature"
                    android:textColor="@color/colorTemp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="6dp" />

                <!-- Temperature LineChart — EXCLUSIVE to temperature data -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_temperature"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Frame 2: pH ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_ph"
                    android:textColor="@color/colorPh"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="6dp" />

                <!-- pH LineChart — EXCLUSIVE to pH data -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_ph"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Frame 3: Glucose ───────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_glucose"
                    android:textColor="@color/colorGlucose"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="6dp" />

                <!-- Glucose LineChart — EXCLUSIVE to glucose data -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_glucose"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
