<?xml version="1.0" encoding="utf-8"?>
<!--
    Requirement 7 — Tab 1: Data View.
    RecyclerView showing historical + live sensor readings.
    tv_empty is shown until the first reading arrives.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Empty-state hint (hidden once readings arrive) -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Hold the NHS 3152 sensor near the phone NFC area to start reading"
        android:textColor="@color/grey_text"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="24dp" />

    <!-- Scrolling list of readings — newest at bottom (auto-scroll) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:visibility="gone" />

</RelativeLayout>
